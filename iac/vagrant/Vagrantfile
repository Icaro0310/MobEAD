# Vagrantfile para projeto Unylea DevOps
# Windows Server 2019 + IIS + Ansible + Terraform

Vagrant.configure("2") do |config|
  config.vm.box = "gusztavoni/windows-server-2019-amd64"
  config.vm.network "private_network", ip: "192.168.56.10"
  config.vm.synced_folder ".", "/vagrant", disabled: false
  config.vm.provider "virtualbox" do |vb, override|
    vb.name = "vm-unylea-winserver-2019"
    vb.memory = "2048"
    vb.cpus = "2"
    vb.customize ["modifyvm", "--natnet1", "enable", "--natnet1", "portforward", "tcp:127.0.0.1:8080-:80"]
    vb.customize ["modifyvm", "--natnet1", "portforward", "tcp:127.0.0.1:3389-:3389"]
    vb.customize ["modifyvm", "--natnet1", "portforward", "tcp:127.0.0.1:5985-:5985"]
  end
end

# Provisionamento com PowerShell
config.vm.provision "shell", inline: <<-SHELL
  # Habilitar WinRM para Ansible
  Write-Host "Configurando WinRM..."
  
  # Configurar WinRM para aceitar conexões básicas
  winrm quickconfig -q -Force
  winrm set winrm/config/service '@{Basic="true"}' -Force
  winrm set winrm/config/service '@{AllowUnencrypted="true"}' -Force
  winrm set winrm/config/client '@{Basic="true"}' -Force
  
  # Criar listener WinRM HTTP
  winrm create winrm/config/Listener?Address=*+Transport=HTTP "@{Port=`"5985`"}" -Force
  
  # Configurar firewall para WinRM
  New-NetFirewallRule -Name "WinRM-HTTP-In" -DisplayName "WinRM over HTTP" -Protocol TCP -LocalPort 5985 -Direction Inbound -Action Allow -Force
  
  # Habilitar RDP
  Set-ItemProperty -Path 'HKLM:\System\CurrentControlSet\Control\Terminal Server' -name "fDenyTSConnections" -value 0 -Force
  Enable-NetFirewallRule -DisplayGroup "Remote Desktop" -Force
  
  # Habilitar IIS
  Write-Host "Instalando IIS..."
  Install-WindowsFeature -Name Web-Server -IncludeManagementTools -Force
  
  # Iniciar serviço IIS
  Start-Service W3SVC -Force
  Set-Service W3SVC -StartupType Automatic
  
  # Criar página HTML personalizada
  $html = @"
<!DOCTYPE html>
<html>
<head>
    <title>Servidor IIS - Unylea DevOps</title>
    <style>
        body { font-family: Arial; text-align: center; margin-top: 50px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; min-height: 100vh; }
        .container { background: rgba(255,255,255,0.1); padding: 30px; border-radius: 10px; backdrop-filter: blur(10px); max-width: 800px; margin: 0 auto; }
        h1 { color: #ffffff; font-size: 2.5em; text-shadow: 2px 2px 4px rgba(0,0,0,0.3); }
        .info { background: rgba(255,255,255,0.2); padding: 20px; margin: 20px 0; border-radius: 5px; }
        .tech { background: rgba(76, 175, 80, 0.3); padding: 10px; border-radius: 5px; display: inline-block; margin: 5px; }
        .vagrant { background: rgba(33, 150, 243, 0.3); padding: 15px; border-radius: 5px; margin: 20px 0; }
        .azure { background: rgba(0, 123, 255, 0.3); padding: 15px; border-radius: 5px; margin: 20px 0; }
    </style>
</head>
<body>
    <div class="container">
        <h1>🎉 Servidor IIS Instalado com Sucesso!</h1>
        <div class="info">
            <h2>Unylea | Engenheiro DevOps | Unidade 4</h2>
            <p><strong>Aluno:</strong> Icaro Galvao do Nascimento</p>
            <p><strong>Ferramentas:</strong> Terraform + Ansible + Azure</p>
            <p><strong>Plataforma:</strong> Windows Server 2019 + IIS</p>
            <p><strong>Status:</strong> ✅ Configurado via Vagrant</p>
            <div>
                <span class="tech">🖥️ Windows Server 2019</span>
                <span class="tech">🌐 IIS</span>
                <span class="tech">🔧 Ansible</span>
                <span class="tech">☁️ Terraform</span>
            </div>
        </div>
        <div class="vagrant">
            <h3>📦 Ambiente Local</h3>
            <p><strong>Vagrant + VirtualBox</strong></p>
            <p>100% gratuito e offline</p>
            <p>Controle total da infraestrutura</p>
        </div>
        <div class="azure">
            <h3>☁️ Interligação Azure</h3>
            <p><strong>Terraform provider Vagrant</strong></p>
            <p>Código IaC mantido</p>
            <p>Entrega no GitHub</p>
        </div>
        <p><em>Provisionado via Vagrant + Ansible</em></p>
        <p><small>Infraestrutura como Código - IaC Híbrido</small></p>
    </div>
</body>
</html>
"@
  
  $html | Out-File -FilePath "C:\\inetpub\\wwwroot\\index.html" -Encoding UTF8 -Force
  
  # Criar script de verificação
  $checkScript = @"
# Script de verificação do servidor
Write-Host "=== Verificação do Servidor IIS ==="
Write-Host "Data: $(Get-Date)"
Write-Host "Hostname: $(hostname)"
Write-Host ""
Write-Host "=== Status do IIS ==="
Get-Service W3SVC | Select-Object Status, Name
Write-Host ""
Write-Host "=== Teste de Conectividade ==="
try {
    $response = Invoke-WebRequest -Uri "http://localhost" -UseBasicParsing $true
    Write-Host "✅ IIS respondendo na porta 80"
    Write-Host "Status: $($response.StatusCode)"
} catch {
    Write-Host "❌ Erro na conexão com IIS"
}
Write-Host ""
Write-Host "=== Configuração WinRM ==="
Test-WSMan -ComputerName localhost -Port 5985 -Http -Authentication Basic -Credential (New-Object System.Management.Automation.PSCredential("vagrant", "vagrant"))
Write-Host "✅ WinRM configurado e funcionando"
Write-Host ""
Write-Host "=== Informações do Sistema ==="
Get-CimInstance | Select-Object Caption, TotalVisibleMemorySize, FreePhysicalMemory
Write-Host ""
Write-Host "=== Logs do IIS ==="
Get-EventLog -LogName System -Source "W3SVC" -Newest 10 | Format-Table TimeStamp, Id, Level, Message
"@
  
  $checkScript | Out-File -FilePath "C:\\check-iis.ps1" -Encoding UTF8 -Force
  
  # Criar atalho para verificação rápida
  $shortcut = @"
@echo off
echo === VERIFICAÇÃO RÁPIDA DO SERVIDOR IIS ===
powershell -ExecutionPolicy Bypass -File C:\\check-iis.ps1
echo ""
echo Acesse o servidor em:
echo - Navegador: http://localhost:8080
echo - RDP: mstsc /v:localhost:3389
echo - WinRM: http://localhost:5985
"@
  
  $shortcut | Out-File -FilePath "C:\\Users\\vagrant\\Desktop\\Verificar Servidor.bat" -Encoding UTF8 -Force
  
  Write-Host "✅ Configuração concluída com sucesso!"
  Write-Host "🌐 Acesse: http://localhost:8080"
  Write-Host "🖥️ RDP: mstsc /v:localhost:3389"
  Write-Host "🔧 WinRM: http://localhost:5985"
  Write-Host "📊 Verificação: C:\\check-iis.ps1"
  Write-Host "🎯 Atalho na área de trabalho: Verificar Servidor.bat"
SHELL

# Criar usuário vagrant com senha (para Ansible)
config.vm.provision "shell", inline: <<-SHELL
  # Criar usuário vagrant com senha
  Write-Host "Criando usuário vagrant com senha..."
  net user vagrant Unylea@2024!DevOps /add:Administradores
  Write-Host "✅ Usuário vagrant criado com sucesso"
SHELL

# Criar arquivo de hosts Ansible
config.vm.provision "file", source: "ansible/inventory-vagrant.ini", destination: "C:/Users/vagrant/inventory.ini"

# Copiar playbook Ansible
config.vm.provision "file", source: "ansible/playbook-iis-vagrant.yml", destination: "C:/Users/vagrant/playbook-iis.yml"

# Copiar scripts de verificação
config.vm.provision "file", source: "scripts/check-ansible.ps1", destination: "C:/check-ansible.ps1"

# Instalar Ansible na VM Windows
config.vm.provision "shell", inline: <<-SHELL
  Write-Host "Instalando Ansible no Windows..."
  
  # Baixar instalador do Ansible
  $url = "https://raw.githubusercontent.com/ansible/ansible/v2.15.8/ansible/setup.exe"
  $output = "C:\\setup-ansible.exe"
  
  Write-Host "Baixando Ansible..."
  Invoke-WebRequest -Uri $url -OutFile $output -UseBasicParsing $true
  
  Write-Host "Instalando Ansible..."
  Start-Process -FilePath $output -ArgumentList "/S" -Wait
  
  Write-Host "Instalando pywinrm..."
  pip install pywinrm
  
  Write-Host "✅ Ansible instalado com sucesso!"
SHELL

end